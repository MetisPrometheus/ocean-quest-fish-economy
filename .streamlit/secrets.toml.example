# Template for Streamlit Cloud's secrets panel.
#
# In your Streamlit Community Cloud app:
#   Settings → Secrets → paste the lines below (without the "example" filename).
#
# The dashboard reads via a READ-ONLY role (`ocean_quest_ro`) and connects
# over public TLS to the Hetzner box. Replace HOST and PASSWORD before pasting.

DATABASE_URL = "postgresql://ocean_quest_ro:READONLY_PASSWORD@HETZNER_PUBLIC_IP:5432/ocean_quest?sslmode=require"
