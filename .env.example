# Local development / on the Hetzner box for the dumper daemon
# Copy this file to `.env` and fill in real values.

ROBLOX_API_KEY=your-roblox-open-cloud-api-key
ROBLOX_UNIVERSE_ID=9995597543

# Daemon writes via this URL (read+write role, localhost — no SSL needed).
# On the Hetzner box this becomes:
#   postgresql://ocean_quest_rw:STRONG_PASSWORD@localhost/ocean_quest
DATABASE_URL=postgresql://ocean_quest_rw:CHANGE_ME@localhost/ocean_quest
